# LifeBoat.ai Configuration Template
# Rename this file to .env to activate

# OPENROUTER API FOR MULTI-MODEL INTELLIGENCE
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Google Maps API Key for Housing & Region Detection
VITE_GMAPS_API_KEY=your_google_maps_api_key_here

# ADZUNA API FOR REAL-TIME JOB SCRAPING (BACKEND)
VITE_ADZUNA_APP_ID=your_adzuna_app_id
VITE_ADZUNA_API_KEY=your_adzuna_api_key
